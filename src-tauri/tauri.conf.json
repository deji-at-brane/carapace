{
  "$schema": "https://schema.web.app/config/2",
  "productName": "Carapace",
  "version": "0.1.0",
  "identifier": "io.carapace.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1425",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Carapace: Universal Agent Terminal",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agent"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
